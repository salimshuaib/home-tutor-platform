rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isVerified() {
      return isAuth() && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    // ─── USERS COLLECTION ───
    // Users can read/write only their own profile
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot self-delete; admin only
    }

    // ─── REQUESTS COLLECTION ───
    // Students can CRUD their own requests; tutors can read all pending requests
    match /requests/{requestId} {
      // Anyone authenticated can read requests (tutors browse pending ones)
      allow read: if isAuth();

      // Only verified users can create, and must set studentUID/userId to their own UID
      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.studentUID == request.auth.uid;

      // Only the owner can update their request
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;

      // BUG 20: Only the owner of the request can delete it
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid
            || resource.data.studentUID == request.auth.uid);
    }

    // ─── LEADS COLLECTION ───
    // Tutors can create leads and read their own leads
    match /leads/{leadId} {
      allow read: if isAuth()
        && resource.data.tutorId == request.auth.uid;

      allow create: if isVerified()
        && request.resource.data.tutorId == request.auth.uid;

      allow update: if isAuth()
        && resource.data.tutorId == request.auth.uid;

      allow delete: if isAuth()
        && resource.data.tutorId == request.auth.uid;
    }

    // ─── DEFAULT: DENY ALL ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
