rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isVerified() {
      return isAuth() && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── VALIDATION HELPERS ───
    function validString(field) {
      return field is string && field.size() > 0;
    }
    function validFullName(data) {
      return data.fullName is string && data.fullName.size() > 2 && data.fullName.size() <= 100;
    }
    function validArrayField(data, field, maxLen) {
      return !data.keys().hasAll([field]) || (data[field] is list && data[field].size() <= maxLen);
    }

    // ─── ADMINS COLLECTION ───
    // Admins can only read their own record. Write is denied (manage via Firebase Console).
    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false;
    }

    // ─── USERS COLLECTION ───
    // Users can read/write only their own profile.
    // Status fields (status, reviewedAt, rejectionReason) can ONLY be changed by admins,
    // EXCEPT: a tutor can reset their own status from "rejected" to "pending" (re-application).
    match /users/{userId} {
      allow read: if isAuth();

      // Create: must be owner, must have fullName > 2 chars, arrays capped at 20
      allow create: if isOwner(userId)
        && validFullName(request.resource.data)
        && validArrayField(request.resource.data, 'subjects', 20)
        && validArrayField(request.resource.data, 'classes', 20)
        && validArrayField(request.resource.data, 'boards', 20)
        && validArrayField(request.resource.data, 'mode', 5);

      // Admin can update any user field
      allow update: if isAdmin();

      // Owner can update their own profile, with restrictions on status fields
      allow update: if isOwner(userId)
        && validFullName(request.resource.data)
        && validArrayField(request.resource.data, 'subjects', 20)
        && validArrayField(request.resource.data, 'classes', 20)
        && validArrayField(request.resource.data, 'boards', 20)
        && validArrayField(request.resource.data, 'mode', 5)
        && (
          // Case 1: No protected fields are being changed
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'reviewedAt', 'rejectionReason'])
          ||
          // Case 2: Re-application — tutor resets from "rejected" to "pending"
          (
            resource.data.get('status', null) == 'rejected'
            && request.resource.data.get('status', null) == 'pending'
            && request.resource.data.get('rejectionReason', null) == null
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewedAt'])
          )
          ||
          // Case 3: Initial application — setting status to pending for the first time
          (
            resource.data.get('status', null) == null
            && request.resource.data.get('status', null) == 'pending'
            && request.resource.data.get('rejectionReason', null) == null
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewedAt'])
          )
        );

      allow delete: if false; // Users cannot self-delete; admin only
    }

    // ─── REQUESTS COLLECTION ───
    // Students can CRUD their own requests; tutors can read and apply to pending requests
    match /requests/{requestId} {
      // Anyone authenticated can read requests (tutors browse pending ones)
      allow read: if isAuth();

      // Only verified users can create, and must set userId to their own UID
      // Required fields: className, subject, location, mode
      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid
        && validString(request.resource.data.className)
        && validString(request.resource.data.subject)
        && validString(request.resource.data.location)
        && validString(request.resource.data.mode);

      // Owner can update their own request (all fields)
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;

      // Tutors can apply: add their UID to appliedTutors and set status to 'active'
      allow update: if isVerified()
        && resource.data.userId != request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appliedTutors', 'status'])
        && request.resource.data.status in ['pending', 'active']
        && request.resource.data.appliedTutors == resource.data.get('appliedTutors', []).concat([request.auth.uid]);

      // Admins can update any request
      allow update: if isAdmin();

      // Only the owner of the request can delete it
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid);
    }

    // ─── LEADS COLLECTION ───
    // Tutors can create leads and read their own leads
    match /leads/{leadId} {
      allow read: if isAuth()
        && resource.data.tutorId == request.auth.uid;

      // Create: must set tutorId to own UID, must have requestId
      allow create: if isVerified()
        && request.resource.data.tutorId == request.auth.uid
        && validString(request.resource.data.requestId);

      allow update: if isAuth()
        && resource.data.tutorId == request.auth.uid;

      allow delete: if isAuth()
        && resource.data.tutorId == request.auth.uid;
    }

    // ─── DEFAULT: DENY ALL ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
